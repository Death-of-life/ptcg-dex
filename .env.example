# Cloudflare API auth for wrangler D1/KV calls.
# Use either CLOUDFLARE_API_TOKEN or CLOUDFLARE_API_KEY + CLOUDFLARE_EMAIL.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare D1/KV.
D1_DATABASE_NAME=
D1_DATABASE_ID=
KV_NAMESPACE_ID=

# R2 bucket and public image URL.
R2_BUCKET_NAME=
CF_R2_PUBLIC_BASE_URL=

# R2 S3 client credentials.
R2_S3_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional sync config.
TCGDEX_BASE_URL=https://api.tcgdex.net/v2
SYNC_LANGS=zh-tw
SYNC_REGULATION_MARKS=H,I,J
D1_MAX_SQL_CHARS=50000
