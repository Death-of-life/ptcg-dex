{
  "name": "ptcg-dex",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "scripts/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @ptcg-dex/web run dev",
    "dev:worker": "npm --workspace @ptcg-dex/worker run dev",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "sync": "npm --workspace @ptcg-dex/sync run sync",
    "openapi:lint": "npm --workspace @ptcg-dex/worker run openapi:lint",
    "api:drift": "node scripts/tools/check-api-drift.mjs",
    "wrangler:render": "node scripts/tools/render-wrangler-config.mjs"
  },
  "devDependencies": {
    "@redocly/cli": "^2.26.0",
    "typescript": "^6.0.2",
    "js-yaml": "^4.1.1"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  }
}
